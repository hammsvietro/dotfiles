{
  "layer": "top",
  "margin": "6 12 6 12",
  "position": "top",
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "tray",
    "bluetooth",
    "hyprland/language",
    "pulseaudio",
    "memory",
    "backlight",
    "battery",
    "clock",
    "custom/notification",
    "custom/power"
  ],
  "custom/launcher": {
    "format": "´îô",
    "tooltip": false,
    "on-click": "rofi -show drun",
    "on-click-right": "killall rofi"
  },
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "´åÆ",
      "default": "´äî"
    },
    "persistent-workspaces": {
      "*": 3
    }
  },
  "hyprland/window": {
    "max-length": 50,
    "separate-outputs": true
  },
  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "format": {
        "months":     "<span color='#ffead3'>{}</span>",
        "days":       "<span color='#ecc6d9'>{}</span>",
        "weekdays":   "<span color='#ffcc66'>{}</span>",
        "today":      "<span color='#ff2800'><u>{}</u></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  "memory": {
    "format": "¾░İÜ {}%",
    "tooltip": true,
    "interval": 5
  },
  "tray": {
    "icon-size": 16,
    "tooltip": false,
    "spacing": 8
  },
  "bluetooth": {
    "format-on": "´èö",
    "format-off": "¾░é▓",
    "format-disabled": "¾░é▓",
    "format-connected": "¾░é▒",
    "on-click": "blueman-manager",
    "tooltip-format-connected": "{device_alias}"
  },
  "network": {
    "format-wifi": "{icon}",
    "format-disconnected": "¾░ñ«",
    "format-icons": ["¾░ñş", "¾░ñó", "¾░ñÑ", "¾░ñ¿"],
    "tooltip-format-wifi": "{essid}",
    "on-click": "nm-connection-editor"
  },
  "pulseaudio": {
    "tooltip": false,
    "format": "{icon} {volume}%",
    "format-muted": "¯╗¿",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click": "pavucontrol",
    "format-icons": {
      "headphone": "´ÇÑ",
      "default": ["´ÇĞ", "´Çğ", "´Ç¿"]
    }
  },
  "backlight": {
    "tooltip": false,
    "format": "¾░âá {}%",
    "interval": 1,
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "tooltip": false,
    "format": "{icon} {capacity}%",
    "format-charging": "´çĞ {capacity}%",
    "format-plugged": "´çĞ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
      "none": "´éó",
      "dnd-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
      "dnd-none": "´çÀ",
      "inhibited-notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
      "inhibited-none": "´éó",
      "dnd-inhibited-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
      "dnd-inhibited-none": "´çÀ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/power": {
    "tooltip": false,
    "format": "´Çæ",
    "on-click": "$HOME/scripts/leave.sh"
  },
  "hyprland/language": {
    "format": "{}",
    "format-en": "en",
    "format-ru": "ru",
    "format-pt": "br"
  }
}
